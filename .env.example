# HSE Emotion Assistant
# Copy this file to `.env` and fill in your own DashScope / Qwen API key.
# This open-source release does not ship with any default API key.

# -------- Required --------
DASHSCOPE_API_KEY=

# Optional: use the international endpoint if needed.
# DASHSCOPE_BASE_HTTP_API_URL=https://dashscope-intl.aliyuncs.com/api/v1

# -------- Text / LLM --------
QWEN_MODEL=qwen3.5-plus
QWEN_ENABLE_THINKING=1
QWEN_THINKING_BUDGET=1999

# -------- Feature Switches --------
HSEMOTION_EMOTION_ENABLED=1
HSEMOTION_RAG_ENABLED=0
HSEMOTION_ASR_ENABLED=0
HSEMOTION_TTS_ENABLED=0

# -------- Vision --------
HSEMOTION_CAMERA_INDEX=0
HSEMOTION_EMOTION_FPS=60
HSEMOTION_EMOTION_ENGINE=libreface
HSEMOTION_MEDIAPIPE_OFFLINE=0
HSEMOTION_WINDOW_COUNT=4
HSEMOTION_BLINK_ENABLED=1
HSEMOTION_AU_ENABLED=1
HSEMOTION_CONTEXT_COMPACTION_ENABLED=1
HSEMOTION_RMES_ENABLED=1
HSEMOTION_RMES_MODE=experiment
HSEMOTION_RMES_ACCEPTANCE_GATE=1
HSEMOTION_GREETING_TEXT=你好 (^_^)，我是智能表情变化以及微表情等数据结合的心理聊天助手！
HSEMOTION_GREETING_VOICE_TEXT=你好，我是你的情绪聊天助手。

# -------- RAG --------
HSEMOTION_RAG_DB_PATH=.rag/rag_store.sqlite3
HSEMOTION_EMBEDDING_MODEL=text-embedding-v4
HSEMOTION_EMBEDDING_DIM=1024
HSEMOTION_RERANK_MODEL=qwen3-rerank
HSEMOTION_RAG_TOP_K=6
HSEMOTION_RAG_CHUNK_CHARS=600
HSEMOTION_RAG_CHUNK_OVERLAP=80

# -------- Realtime ASR --------
HSEMOTION_ASR_MODEL=gummy-realtime-v1
HSEMOTION_ASR_SAMPLE_RATE=16000

# -------- Realtime TTS --------
HSEMOTION_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime?model=qwen3-tts-flash-realtime
HSEMOTION_TTS_VOICE=Cherry
HSEMOTION_TTS_SAMPLE_RATE=24000
HSEMOTION_TTS_LANGUAGE=Auto

# -------- Omni Realtime --------
HSEMOTION_OMNI_ENABLED=1
HSEMOTION_OMNI_MODEL=qwen3-omni-flash-realtime
HSEMOTION_OMNI_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
HSEMOTION_OMNI_VOICE=Cherry
HSEMOTION_OMNI_INPUT_SAMPLE_RATE=16000
HSEMOTION_OMNI_OUTPUT_SAMPLE_RATE=24000
HSEMOTION_OMNI_ENABLE_VIDEO=1
HSEMOTION_OMNI_VIDEO_FPS=1.0
HSEMOTION_OMNI_LOCAL_BARGE_IN_ENABLED=1
HSEMOTION_OMNI_LOCAL_BARGE_IN_RMS=900
HSEMOTION_OMNI_LOCAL_BARGE_IN_COOLDOWN_S=0.8
HSEMOTION_OMNI_VOICE_INSTRUCTIONS=当前是纯语音对话。请尽量短答：默认 1 到 2 句，优先一句话说完。除非用户明确追问或要求展开，否则不要长解释、不要分点、不要铺垫。如果只是接话、安抚、确认、追问，尽量控制在 8 到 24 个中文字符的自然口语范围。
HSEMOTION_OMNI_TRANSCRIPTION_MODEL=qwen3-asr-flash-realtime
